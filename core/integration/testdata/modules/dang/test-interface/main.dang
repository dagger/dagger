type TestInterface {
  # Implement an interface defined by a dependency, then use the
  # implementation. Conforming to `Dep_Greeter` must not require providing
  # the synthesized `id: ID!` field that Dagger adds to every interface.
  pub run: String! {
    Hi.greet("world")
  }

  # Define, implement, and consume an interface entirely within this module.
  pub local: String! {
    greetWith(Hey)
  }

  pub greetWith(g: Local!): String! {
    g.greet("local")
  }
}

# Implements an interface imported from the `dep` dependency. The Dagger
# schema synthesizes `id: ID!` on every interface; the implementer must
# not be required to provide it (Dagger supplies it).
type Hi implements Dep_Greeter {
  pub greet(name: String!): String! {
    "hi, " + name
  }
}

interface Local {
  pub greet(name: String!): String!
}

type Hey implements Local {
  pub greet(name: String!): String! {
    "hey, " + name
  }
}
