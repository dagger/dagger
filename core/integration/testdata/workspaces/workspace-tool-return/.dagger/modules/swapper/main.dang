"""Tools that return a Workspace, for @agent integration tests."""
type Swapper {
  """
  Return the current workspace with a marker file added.

  The auto-injected Workspace! is the agent's current workspace; returning a
  derived one exercises the tool -> workspace rebinding (a tool that returns a
  Workspace replaces the LLM's current workspace, mirroring Changeset overlay).
  """
  swap(ws: Workspace!): Workspace! {
    ws.withNewFile("SWAPPED.txt", "swapped by tool")
  }
}
