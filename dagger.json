{
  "name": "dagger-dev",
  "engineVersion": "v0.20.6",
  "toolchains": [
    {
      "name": "changelog",
      "source": "toolchains/changelog"
    },
    {
      "name": "ci",
      "source": "toolchains/ci"
    },
    {
      "name": "cli",
      "source": "toolchains/cli-dev"
    },
    {
      "name": "docs",
      "source": "toolchains/docs-dev"
    },
    {
      "name": "elixir-sdk",
      "source": "toolchains/elixir-sdk-dev"
    },
    {
      "name": "engine-dev",
      "source": "toolchains/engine-dev"
    },
    {
      "name": "go",
      "source": "toolchains/go",
      "customizations": [
        {
          "argument": "source",
          "ignore": [
            "bin",
            ".git",
            "**/node_modules",
            "**/.venv",
            "**/__pycache__",
            "**/sdk/runtime/**",
            "docs/node_modules",
            "sdk/typescript/node_modules",
            "sdk/typescript/dist",
            "sdk/rust/examples/backend/target",
            "sdk/rust/target",
            "sdk/php/vendor",
            "docs/**",
            "dagql/idtui/viztest/broken/**",
            "**/broken*/**",
            "core/integration/testdata/checks/hello-with-checks/",
            "core/integration/testdata/generators/hello-with-generators/",
            "core/integration/testdata/services/hello-with-services/",
            "core/integration/testdata/services/port-collision/",
            "core/integration/testdata/services/partial-failure/",
            "core/integration/testdata/services/service-binding/",
            "toolchains/release/testdata/module/"
          ]
        }
      ]
    },
    {
      "name": "go-sdk",
      "source": "toolchains/go-sdk-dev"
    },
    {
      "name": "golang",
      "source": "github.com/dagger/go@main",
      "pin": "4985ec6b9752e9deac3d37276c0f8a33ceba30bf",
      "customizations": [
        {
          "argument": "selectModule",
          "default": "e2e/*"
        }
      ]
    },
    {
      "name": "helm",
      "source": "github.com/dagger/helm@main",
      "pin": "d0a7e172e8212b31c6061bb699495b1e8ba0958f"
    },
    {
      "name": "java-sdk",
      "source": "toolchains/java-sdk-dev"
    },
    {
      "name": "markdown-lint",
      "source": "modules/markdownlint"
    },
    {
      "name": "php-sdk",
      "source": "toolchains/php-sdk-dev"
    },
    {
      "name": "ps-analyzer",
      "source": "github.com/dagger/PsScriptAnalyzer@main",
      "pin": "d87a12883dccd495bee98da9d2c20eb44b6f608d"
    },
    {
      "name": "python-sdk",
      "source": "toolchains/python-sdk-dev"
    },
    {
      "name": "release",
      "source": "toolchains/release"
    },
    {
      "name": "rust-sdk",
      "source": "toolchains/rust-sdk-dev"
    },
    {
      "name": "sdks",
      "source": "toolchains/all-sdks"
    },
    {
      "name": "security",
      "source": "toolchains/security",
      "customizations": [
        {
          "function": [
            "scanSource"
          ],
          "argument": "source",
          "ignore": [
            "bin",
            ".git",
            "docs",
            "sdk/rust/examples",
            "sdk/rust/crates/dagger-sdk/examples",
            "core/integration/testdata",
            "dagql/idtui/viztest"
          ]
        }
      ]
    },
    {
      "name": "shellcheck",
      "source": "github.com/dagger/shellcheck@main",
      "pin": "34bcb268f4483fa31ea9e33b6a86aa7892144323"
    },
    {
      "name": "test-split",
      "source": "toolchains/test-split"
    },
    {
      "name": "typescript-sdk",
      "source": "toolchains/typescript-sdk-dev"
    }
  ]
}
