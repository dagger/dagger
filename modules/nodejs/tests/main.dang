type Tests {
  let fixtureRoot: String! = "modules/nodejs/tests/testdata/workspace"

  let fixturePackages(ws: Workspace!): [Package!]! {
    nodejs
      .packages(ws)
      .filter { pkg =>
        pkg.path == fixtureRoot or
          pkg.path == fixtureRoot + "/apps/admin" or
          pkg.path == fixtureRoot + "/apps/web" or
          pkg.path == fixtureRoot + "/shared/lib"
      }
  }

  """
  Discover package.json files beneath the fixture workspace.
  """
  pub discoversPackages(ws: Workspace!): Void @check {
    let packages = fixturePackages(ws)
    if (packages.length != 4) {
      raise "expected 4 fixture packages"
    }

    let ignored = nodejs
      .packages(ws)
      .filter { pkg => pkg.path == fixtureRoot + "/apps/web/node_modules/ignored" }
      .length > 0
    if (ignored) {
      raise "package discovery should ignore node_modules"
    }

    null
  }

  """
  Read the custom package.json ports key.
  """
  pub readsPorts(ws: Workspace!): Void @check {
    let web = nodejs.package(ws, fixtureRoot + "/apps/web")
    if (web.ports.length != 2) {
      raise "expected 2 ports for apps/web"
    }

    let has3000 = web.ports.filter { port => port == 3000 }.length > 0
    let has3001 = web.ports.filter { port => port == 3001 }.length > 0
    if (has3000 == false or has3001 == false) {
      raise "apps/web ports were not parsed correctly"
    }

    let admin = nodejs.package(ws, fixtureRoot + "/apps/admin")
    let has8080 = admin.ports.filter { port => port == 8080 }.length > 0
    if (has8080 == false) {
      raise "apps/admin ports were not parsed correctly"
    }

    null
  }

  """
  Parse the package manager from package.json.
  """
  pub readsPackageManager(ws: Workspace!): Void @check {
    let admin = nodejs.package(ws, fixtureRoot + "/apps/admin")
    if (admin.packageManager != "pnpm") {
      raise "expected apps/admin package manager to be pnpm"
    }

    let web = nodejs.package(ws, fixtureRoot + "/apps/web")
    if (web.packageManager != "npm") {
      raise "expected apps/web package manager to be npm"
    }

    null
  }

  pub all(ws: Workspace!): Void @check {
    discoversPackages(ws)
    readsPorts(ws)
    readsPackageManager(ws)
    null
  }
}
