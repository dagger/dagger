{
  "name": "@dagger.io/dagger",
  "version": "0.0.0",
  "author": "hello@dagger.io",
  "license": "Apache-2.0",
  "types": "./dist/src/index.d.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": "./dist/src/index.js",
    "./telemetry": "./dist/src/telemetry/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist/src/index.js",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@lifeomic/axios-fetch": "^3.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/exporter-jaeger": "^2.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "adm-zip": "^0.6.0",
    "env-paths": "^4.0.0",
    "execa": "^10.0.0",
    "graphql": "^17.0.2",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.7",
    "node-color-log": "^14.0.0",
    "node-fetch": "^3.3.2",
    "reflect-metadata": "^0.2.2",
    "tar": "^7.5.20",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "yarn run test:node",
    "test:bun": "bun run --bun mocha",
    "test:node": "mocha",
    "test:generate-scan": "tsx ./introspector/test/testdata/generate_expected_scan.ts",
    "lint": "yarn eslint --max-warnings=0 .",
    "fmt": "yarn eslint --max-warnings=0 --fix .",
    "docs:lint": "cd ../../docs/current_docs && eslint -c ../../sdk/typescript/eslint-docs.config.js --max-warnings=0 ./**/*.ts",
    "docs:fmt": "cd ../../docs/current_docs && eslint --fix -c ../../sdk/typescript/eslint-docs.config.js --max-warnings=0 ./**/*.ts"
  },
  "resolutions": {
    "@grpc/grpc-js": "1.14.4",
    "@trivago/prettier-plugin-sort-imports/lodash-es": "4.18.1",
    "@trivago/prettier-plugin-sort-imports/minimatch": "9.0.9",
    "**/@grpc/proto-loader/protobufjs": "7.6.1",
    "**/@opentelemetry/otlp-transformer/protobufjs": "8.4.1",
    "**/glob/minimatch": "9.0.9",
    "form-data": "4.0.6",
    "mocha/minimatch": "9.0.9",
    "mocha/serialize-javascript": "7.0.3",
    "tsx/esbuild": "0.28.1"
  },
  "devDependencies": {
    "@dagger.io/mocha": "^0.1.0",
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/adm-zip": "^0.5.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "~26.1.1",
    "@types/tar": "^7.0.87",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "mocha": "^11.7.6",
    "prettier": "^3.9.5",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript-eslint": "^8.64.0"
  }
}
