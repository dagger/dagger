pub description = "Toolchain to run github.com/dagger/go checks for the Dagger repository"

type Golang {
  let toolchain: Go! {
    go(
      test: ["e2e/**"],
      lint: ["!**"],
      generate: ["docs/current_docs/reference"],
    )
  }

  """
  Run golangci-lint in every discovered Go module.
  """
  pub lintAll: Void @check {
    toolchain.lintAll(currentWorkspace)
  }

  """
  Run tests in every discovered Go module.
  """
  pub testAll: Void @check {
    toolchain.testAll(currentWorkspace)
  }

  """
  Run go generate in every discovered Go module.
  """
  pub generateAll: Changeset! @generate {
    toolchain.generateAll(currentWorkspace)
  }
}
