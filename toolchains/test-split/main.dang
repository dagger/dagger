"""
Test suites to run
"""
type TestSplit {
  """
  Lower-level API for running specific tests
  """
  pub testSpecific(
    run: [String!]!,
    ebpfProgs: [String!],
    pkg: String! = "./core/integration",
    race: Boolean,
    parallel: Int,
    timeout: String,
  ): Void {
    engineDev.test(race: race, run: run.join("|"), ebpfProgs: ebpfProgs, pkg: pkg, parallel: parallel, timeout: timeout)
  }

  let testCliEngineSpecific(
    run: [String!]!,
    ebpfProgs: [String!],
    pkg: String! = "./core/integration",
    race: Boolean,
  ): Void {
    engineDev
      .withEngineConfig("worker.oci", [
        "minFreeSpace = \"30%\"",
        "maxUsedSpace = \"50%\"",
      ].join("\n"))
      .test(race: race, run: run.join("|"), ebpfProgs: ebpfProgs, pkg: pkg)
  }

  let testSkip(
    skip: [String!]!,
    ebpfProgs: [String!],
    pkg: String! = "./core/integration",
    race: Boolean,
  ): Void {
    engineDev.test(race: race, skip: skip.join("|"), ebpfProgs: ebpfProgs, pkg: pkg)
  }

  """
  Test Base
  """
  pub testBase: Void @check {
    testSkip(
      skip: ["TestProvision", "TestTelemetry", "TestModule", "TestGo", "TestPython", "TestTypescript", "TestElixir", "TestPHP", "TestJava", "TestContainer", "TestDockerfile", "TestLLM", "TestCLI", "TestEngine", "TestCachePersistence", "TestLocalCache", "TestClientGenerator", "TestInterface", "TestCall", "TestShell", "TestDaggerCMD", "TestWorkspace", "TestCollection$"],
      pkg: "./...",
      race: true,
    )
  }

  """
  Test Provision
  """
  pub testProvision: Void @check {
    testSpecific(["TestProvision"])
  }

  """
  Test Telemetry
  """
  pub testTelemetry: Void @check {
    testSpecific(["TestTelemetry"], pkg: "./dagql/idtui")
  }

  """
  Test Call and Shell
  """
  pub testCallAndShell: Void @check {
    testSpecific(["TestCall", "TestShell", "TestDaggerCMD"])
  }

  """
  Test CLI Engine
  """
  pub testCliEngine: Void @check {
    testCliEngineSpecific(["TestCLI", "TestEngine"])
  }

  """
  Test cache persistence
  """
  pub testCachePersistence: Void @check {
    testCliEngineSpecific(["TestCachePersistence"])
  }

  """
  Test local cache
  """
  pub testLocalCache: Void @check {
    testCliEngineSpecific(["TestLocalCache"])
  }

  """
  Test Client Generator
  """
  pub testClientGenerator: Void @check {
    testSpecific(["TestClientGenerator"])
  }

  """
  Test Container
  """
  pub testContainer: Void @check {
    testSpecific(["TestContainer", "TestDockerfile"])
  }

  """
  Test Interface
  """
  pub testInterface: Void @check {
    testSpecific(["TestInterface"])
  }

  """
  Test LLM
  """
  pub testLlm: Void @check {
    testSpecific(["TestLLM"])
  }

  """
  Test Module Runtimes
  """
  pub testModuleRuntimes: Void @check {
    testSpecific(["TestGo", "TestPython", "TestTypescript", "TestElixir", "TestPHP", "TestJava"])
  }

  """
  Test Modules
  """
  pub testModules: Void @check {
    testSpecific(["TestModule"])
  }

  """
  Test Workspaces
  """
  pub testWorkspaces: Void @check {
    testSpecific(["TestWorkspace"])
  }

  """
  Test Collections

  Runs the collection integration suite. Each test boots a nested dev
  engine, which is too slow for the race-enabled base shard. The skip
  pattern is anchored so the collection unit tests stay in the base
  shard.
  """
  pub testCollections: Void @check {
    # Every collection test boots a nested dev engine; unbounded test
    # parallelism saturates the runner and stalls engine sessions, so
    # bound it, and keep the check-selection half in its own shard.
    # timeout below the 30m session cap, so a wedged engine session fails
    # fast with a goroutine dump instead of a silent cancellation.
    testSpecific(["TestCollection$/TestPublicSurface", "TestCollection$/TestAlgebraLaws", "TestCollection$/TestGeneratedClients", "TestCollection$/TestCacheReplay", "TestCollection$/TestKeyTypes"], parallel: 4, timeout: "20m")
  }

  """
  Test Collection Check Selection
  """
  pub testCollectionChecks: Void @check {
    # The check-selection tests execute real checks on top of nested
    # engines: the heaviest collection tests, sharded separately.
    testSpecific(["TestCollection$/TestCheckSelection"], parallel: 4, timeout: "20m")
  }
}
